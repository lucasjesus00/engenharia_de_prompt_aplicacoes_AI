import math

def eh_primo(n):
    # Números menores ou iguais a 1 não são considerados primos
    if n <= 1:
        return False
    
    # O número 2 é o único primo par
    if n == 2:
        return True
    
    # Se o número for par e maior que 2, ele não pode ser primo
    if n % 2 == 0:
        return False

    # Otimização: Não precisamos testar todos os números até n.
    # Se n tiver um divisor, ele será encontrado até a sua raiz quadrada.
    # O range(3, ..., 2) testa apenas números ímpares (3, 5, 7...)
    limite = int(math.sqrt(n)) + 1
    for i in range(3, limite, 2):
        if n % i == 0:
            # Se encontrar qualquer divisor, retorna Falso imediatamente
            return False
            
    # Se o loop terminar sem encontrar divisores, o número é primo
    return True

