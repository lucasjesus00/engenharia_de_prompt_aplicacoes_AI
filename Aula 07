        if chute in letras_descobertas or chute in letras_erradas:
            print(f">> Você já tentou a letra '{chute}'. Tente outra!")
            continue

        # Usando a função modular que criamos
        if verificar_letra(palavra_secreta, letras_descobertas, chute):
