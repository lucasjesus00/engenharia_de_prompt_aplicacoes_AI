import random

def verificar_letra(palavra_secreta, letras_descobertas, letra_palpite):
    """
    Lógica modular: percorre a palavra e atualiza o progresso se a letra existir.
    """
    acerto = False
    for i in range(len(palavra_secreta)):
        if palavra_secreta[i] == letra_palpite:
            letras_descobertas[i] = letra_palpite
            acerto = True
    return acerto

def jogar_forca():
    # Setup inicial do Júnior
    palavras = ["teclado", "monitor", "software", "backend", "algoritmo"]
    palavra_secreta = random.choice(palavras).lower()
    letras_descobertas = ["_" for _ in palavra_secreta]
    
    tentativas_restantes = 6
    letras_erradas = []

    print("--- BEM-VINDO AO JOGO DA FORCA ---")

    while tentativas_restantes > 0 and "_" in letras_descobertas:
